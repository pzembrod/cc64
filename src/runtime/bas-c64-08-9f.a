
; cc64 runtime module start
; to run on c64 at $0801-$a000

!set    cc64_statics_start = $a000
!addr   cc64_statics_end   = $a000
!addr   cc64_frameptr      = $fd
!addr   cc64_zp            = $fb

!addr   tmp_zp1            = $22
!addr   tmp_zp2            = $24

!addr   strout    = $ab1e
!addr   warmstart = $e37b

!ct pet ; use PETSCII for char constants - important e.g. for printf.a

+cc64_runtime_start $0801

cc64_lib_start
        !word baslink
        !word 2026
        !byte $9e      ; sys
        !pet           " 2081:" ; the string address here must match ...
        !addr sys_addr = 2081   ; ... the int address here for checking
        !byte $8f      ; rem
        !pet " cc64 rt-lib v1.0", 0
baslink !word 0

!ifndef cc64_generate_statics {
  !if * != sys_addr {
          !error "sys address ", sys_addr, " should be ", *
  }
}

        jmp init

division_by_zero
        lda #<div_zero
        ldy #>div_zero
        jsr strout
        jmp warmstart
div_zero !pet "division by zero", $0d, 0
